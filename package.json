{
  "name": "langchain-pi-ts",
  "version": "0.1.0",
  "description": "LangChain BaseChatModel adapter for @earendil-works/pi-ai — use Pi with any provider, model and auth.",
  "type": "module",
  "types": "./dist/index.d.ts",
  "module": "./dist/index.js",
  "main": "./dist/index.js",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "engines": {
    "node": ">=22.19.0"
  },
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "format": "biome format --write .",
    "check": "biome check --write .",
    "prepublishOnly": "bun run build"
  },
  "keywords": [
    "langchain",
    "pi",
    "pi-ai",
    "llm",
    "chat-model",
    "adapter"
  ],
  "license": "MIT",
  "author": "cgaravitoq",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/cgaravitoq/langchain-pi-ts.git"
  },
  "homepage": "https://github.com/cgaravitoq/langchain-pi-ts#readme",
  "bugs": {
    "url": "https://github.com/cgaravitoq/langchain-pi-ts/issues"
  },
  "dependencies": {
    "@earendil-works/pi-ai": "^0.78.0",
    "@earendil-works/pi-coding-agent": "^0.78.0"
  },
  "peerDependencies": {
    "@langchain/core": "^1.1.44"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.16",
    "@langchain/core": "^1.1.48",
    "@types/bun": "^1.3.14",
    "tsup": "^8.5.0",
    "typescript": "^6.0.3"
  }
}
