{
  "name": "@cgaravitoq/open-langchain-ts",
  "version": "0.5.1",
  "description": "Native LangChain BaseChatModel adapters for the Claude Code OAuth subscription (Anthropic) and opencode/Zen — no Pi, no API key.",
  "type": "module",
  "types": "./dist/index.d.ts",
  "module": "./dist/index.js",
  "main": "./dist/index.js",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./opencode": {
      "types": "./dist/opencode-chat.d.ts",
      "import": "./dist/opencode-chat.js"
    },
    "./claude-code": {
      "types": "./dist/claude-code-chat.d.ts",
      "import": "./dist/claude-code-chat.js"
    },
    "./codex": {
      "types": "./dist/codex-chat.d.ts",
      "import": "./dist/codex-chat.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "engines": {
    "node": ">=22.19.0"
  },
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "format": "biome format --write .",
    "check": "biome check --write .",
    "prepublishOnly": "bun run build"
  },
  "keywords": [
    "langchain",
    "claude-code",
    "opencode",
    "anthropic",
    "llm",
    "chat-model",
    "adapter"
  ],
  "license": "MIT",
  "author": "cgaravitoq",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/cgaravitoq/open-langchain-ts.git"
  },
  "homepage": "https://github.com/cgaravitoq/open-langchain-ts#readme",
  "bugs": {
    "url": "https://github.com/cgaravitoq/open-langchain-ts/issues"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.91.1",
    "@cgaravitoq/claude-code-core": "file:../claude-code-core",
    "@langchain/openai": "^1.4.7"
  },
  "peerDependencies": {
    "@langchain/core": "^1.1.44"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.16",
    "@langchain/core": "^1.1.48",
    "@types/bun": "^1.3.14",
    "tsup": "^8.5.0",
    "typescript": "^6.0.3"
  }
}
